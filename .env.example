# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=haberfoni
MYSQL_USER=haberfoni_user
MYSQL_PASSWORD=your_db_password

# Web App & Prisma Configuration
# Docker içinde @db, local geliştirmede @localhost kullan
DATABASE_URL="mysql://haberfoni_user:your_db_password@db:3306/haberfoni"

# Bot Configuration
MYSQL_HOST=localhost

# AI Configuration (Google AI Studio'dan ücretsiz key al: https://aistudio.google.com)
AI_API_KEY=your_gemini_api_key_here
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# Opsiyonel: Groq fallback için (https://console.groq.com - ücretsiz)
# GROQ_API_KEY=your_groq_key_here
